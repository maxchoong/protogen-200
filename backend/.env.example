# GitHub Models API Configuration (Phase 3)
# Free tier: 150 requests/day
# Get your token at: https://github.com/settings/tokens?type=beta
# Required permission: GitHub Copilot (Read-only) OR models:read
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_MODEL=gpt-4o-mini

# OMDb API Configuration
# Free tier test key (for development only)
# Get dedicated key at: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=trilogy

# TMDB API Configuration (Phase 4 - Trailers)
# Free tier available
# Get API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Streaming Availability API (Phase 4 - Where to Watch)
# Via RapidAPI, Free tier: 100 requests/day
# Sign up at: https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability
RAPIDAPI_KEY=your_rapidapi_key_here

# Backend Configuration
PORT=3000
NODE_ENV=development

# TMDB Region (optional, defaults to US)
TMDB_REGION=US
